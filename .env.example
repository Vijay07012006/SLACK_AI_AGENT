# Database (Neon/Postgres)
DATABASE_URI=postgresql://your_username:your_password@your_host:5432/your_db

# Slack
SLACK_BOT_TOKEN=xoxb-your_bot_token_here
SLACK_APP_TOKEN=xapp-your_app_token_here
SLACK_SIGNING_SECRET=your_signing_secret_here
SLACK_PRIVATE_CHANNEL_ID=your_channel_id_here

# AI (Groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
AUTO_DM_THRESHOLD=85
SALES_TAG_THRESHOLD=60
AUTO_ENABLED=true

# Google Sheets CRM
GOOGLE_CREDENTIALS=your_google_credentials_json_string
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# App Config
COMPANY_NAME=your_company_name
COMPANY_PRODUCT=your_product_name
PORT=3000
NODE_ENV=production
DB_SSL_ENABLED=true
